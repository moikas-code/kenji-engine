{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@kenji-engine/core": ["./packages/core/src"],
      "@kenji-engine/pixel-art-generator": ["./packages/pixel-art-generator/src"],
      "@kenji-engine/mcp-server": ["./packages/mcp-server/src"],
      "@kenji-engine/butler-deploy": ["./packages/butler-deploy/src"],
      "@kenji-engine/cli": ["./packages/cli/src"]
    }
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
