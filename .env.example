# Kuuzuki Game Engine Environment Variables

# Development Environment
NODE_ENV=development

# MCP Server Configuration
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost

# Knowledge Base Configuration
KB_PATH=./kb
KB_BACKEND=filesystem

# Butler (itch.io) Configuration
BUTLER_API_KEY=your_butler_api_key_here
ITCH_USER=your_itch_username
ITCH_GAME=your_game_name

# Game Engine Configuration
GAME_TITLE="My Game"
GAME_VERSION=1.0.0
GAME_AUTHOR="Your Name"

# Build Configuration
BUILD_TARGET=web
BUILD_MODE=development

# Asset Configuration
ASSET_PATH=./assets
PIXEL_ART_SCALE=2

# Audio Configuration
AUDIO_ENABLED=true
AUDIO_VOLUME=0.8

# Debug Configuration
DEBUG_MODE=true
DEBUG_PHYSICS=false
DEBUG_RENDERING=false

# Performance Configuration
TARGET_FPS=60
VSYNC_ENABLED=true